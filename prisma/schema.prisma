generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  user
  publisher
}

enum MediaType {
  image
  video
}

enum UserStatus {
  attending
  interested
  none
}

enum ImageType {
  event
  gallery
}

enum ImageStatus {
  pending
  approved
  rejected
}

model User {
  id           String    @id @default(uuid())
  name         String?
  lastName     String?
  birthdate    DateTime?
  gender       String?
  username     String    @unique
  description  String?
  email        String    @unique
  password     String
  refreshToken String? // para almacenar el último refresh token válido
  avatar       String?
  location     String?
  phone        String?
  isVerified   Boolean   @default(false)

  role      Role     @default(user)
  createdAt DateTime @default(now())
  Event     Event[]

  following         Follow[]           @relation("FollowingRelation")
  followers         Follow[]           @relation("FollowerRelation")
  EventInterest     EventInterest[]
  Ticket            Ticket[]
  EventAttendance   EventAttendance[]
  eventImages       EventImage[]
  categories        Category[]         @relation("UserCategories")
  verificationCodes VerificationCode[]
}

model VerificationCode {
  id        String    @id @default(uuid())
  userId    String
  code      String
  attempts  Int       @default(0)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Category {
  id    String  @id @default(uuid())
  name  String
  Event Event[]
  users User[]  @relation("UserCategories")
}

model Event {
  id          String     @id @default(uuid())
  slug        String     @unique
  title       String
  description String
  mediaType   MediaType
  mediaUrl    String
  cost        Float
  currency    String     @default("USA")
  gallery     String[]   @default([])
  location    String
  lat         Float?
  log         Float?
  eventDate   DateTime
  attendees   Int
  userStatus  UserStatus @default(none)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  //Relaciones
  user   User   @relation(fields: [userId], references: [id])
  userId String

  category         Category          @relation(fields: [categoryId], references: [id])
  categoryId       String
  EventInterest    EventInterest[]
  TicketItem       TicketItem[]
  EventImage       EventImage[]
  EventAttendance  EventAttendance[]
  eventTicketTypes EventTicketType[]
}

model EventImage {
  id     Int         @id @default(autoincrement())
  url    String
  type   ImageType   @default(event)
  status ImageStatus @default(pending)

  event   Event  @relation(fields: [eventId], references: [id])
  eventId String

  user   User   @relation(fields: [userId], references: [id])
  userId String

  createdAt DateTime @default(now())
}

model EventTicketType {
  id         String    @id @default(uuid())
  name       String
  price      Float
  quantity   Int
  validUntil DateTime?

  event   Event  @relation(fields: [eventId], references: [id])
  eventId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Follow {
  id         String @id @default(uuid())
  follower   User   @relation("FollowingRelation", fields: [followerId], references: [id])
  followerId String

  following   User   @relation("FollowerRelation", fields: [followingId], references: [id])
  followingId String

  createdAt DateTime @default(now())

  @@unique([followerId, followingId]) // evita duplicados
}

model EventInterest {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  event     Event    @relation(fields: [eventId], references: [id])
  eventId   String
  createdAt DateTime @default(now())

  @@unique([userId, eventId]) // 👈 evita duplicados
}

model EventAttendance {
  id     String @id @default(uuid())
  user   User   @relation(fields: [userId], references: [id])
  userId String

  event   Event  @relation(fields: [eventId], references: [id])
  eventId String

  createdAt DateTime @default(now())

  @@unique([userId, eventId]) // evita duplicados
}

model Ticket {
  id           String    @id @default(uuid())
  subTotal     Float
  tax          Float
  total        Float
  itemsInOrder Int
  isPaid       Boolean   @default(false)
  paidAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  //Relaciones
  user   User   @relation(fields: [userId], references: [id])
  userId String

  transactionId String?
  TicketItem    TicketItem[]
}

model TicketItem {
  id       String @id @default(uuid())
  quantity Int
  price    Float

  ticket   Ticket @relation(fields: [ticketId], references: [id])
  ticketId String

  event   Event  @relation(fields: [eventId], references: [id])
  eventId String
}

model Notification {
  id        String   @id @default(uuid())
  title     String
  message   String
  type      String   @default("info") // info | warning | error | success
  userId    String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
