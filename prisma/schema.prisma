generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  user
  publisher
}

enum MediaType {
  image
  video
}

enum UserStatus {
  attending
  interested
  none
}

model User {
  id           String   @id @default(uuid())
  name         String
  username     String   @unique
  description  String?
  email        String   @unique
  password     String
  refreshToken String? // para almacenar el último refresh token válido
  avatar       String?
  interests    String[] @default([])

  role      Role     @default(user)
  createdAt DateTime @default(now())
  Event     Event[]

  following     Follow[]        @relation("FollowingRelation")
  followers     Follow[]        @relation("FollowerRelation")
  EventInterest EventInterest[]
  Ticket        Ticket[]
}

model Category {
  id    String  @id @default(uuid())
  name  String
  Event Event[]
}

model Event {
  id          String     @id @default(uuid())
  title       String
  description String
  mediaType   MediaType
  mediaUrl    String
  cost        Float
  currency    String
  gallery     String[]   @default([])
  location    String
  eventDate   DateTime
  attendees   Int
  userStatus  UserStatus @default(none)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  //Relaciones
  user   User   @relation(fields: [userId], references: [id])
  userId String

  category      Category        @relation(fields: [categoryId], references: [id])
  categoryId    String
  EventInterest EventInterest[]
  TicketItem    TicketItem[]
}

model Follow {
  id         String @id @default(uuid())
  follower   User   @relation("FollowingRelation", fields: [followerId], references: [id])
  followerId String

  following   User   @relation("FollowerRelation", fields: [followingId], references: [id])
  followingId String

  createdAt DateTime @default(now())

  @@unique([followerId, followingId]) // evita duplicados
}

model EventInterest {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  event     Event    @relation(fields: [eventId], references: [id])
  eventId   String
  createdAt DateTime @default(now())

  @@unique([userId, eventId]) // 👈 evita duplicados
}

model Ticket {
  id           String    @id @default(uuid())
  subTotal     Float
  tax          Float
  total        Float
  itemsInOrder Int
  isPaid       Boolean   @default(false)
  paidAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  //Relaciones
  user   User   @relation(fields: [userId], references: [id])
  userId String

  transactionId String?
  TicketItem    TicketItem[]
}

model TicketItem {
  id       String @id @default(uuid())
  quantity Int
  price    Float

  ticket   Ticket @relation(fields: [ticketId], references: [id])
  ticketId String

  event   Event  @relation(fields: [eventId], references: [id])
  eventId String
}
